{
  "name": "justdo-vue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.1.11",
    "chart.js": "^4.4.9",
    "heroicons": "^2.2.0",
    "pinia": "^2.3.1",
    "uuid": "^11.1.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/chart.js": "^2.9.41",
    "@types/node": "^22.14.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "axe-core": "^4.10.2",
    "eslint": "^9.36.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.11",
    "terser": "^5.36.0",
    "ts-node": "^10.9.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
